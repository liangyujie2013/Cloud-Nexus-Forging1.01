# =============================================================================
# CNF v1.0.1 控制面环境变量示例
# 复制为 /etc/cnf/server.env（或本地 .env）并按需修改。
#
# 数据库方向：MySQL 8.0 / MariaDB 10.5+（主数据）+ Redis 7（缓存 / 分布式锁）。
# 变量名必须与 internal/config/config.go 中 Load() 读取的键完全一致。
# =============================================================================

# 服务监听地址（host:port，留空 host 表示监听全部网卡）
CNF_LISTEN_ADDR=:8080

# ---- MySQL / MariaDB（go-sql-driver DSN，必须含 parseTime=true）----
# 格式：user:pass@tcp(host:port)/dbname?参数
CNF_MYSQL_DSN=cnf:cnf@tcp(127.0.0.1:3306)/cnf?parseTime=true&charset=utf8mb4&loc=Local
CNF_MYSQL_MAX_OPEN=20
CNF_MYSQL_MAX_IDLE=5

# ---- Redis（缓存 / 分布式锁 / 指标缓冲）----
CNF_REDIS_ADDR=127.0.0.1:6379
CNF_REDIS_PASSWORD=
CNF_REDIS_DB=0

# ---- 鉴权 / JWT（生产环境务必更换为强随机值）----
CNF_JWT_SECRET=change-me-in-production
CNF_JWT_EXPIRE_HOURS=24

# ---- 数据库迁移目录（相对工作目录或绝对路径）----
CNF_MIGRATIONS_DIR=migrations/mysql

# ---- libvirt 默认远程连接方式（host 表内可逐主机覆盖）----
CNF_LIBVIRT_TRANSPORT=tcp
CNF_LIBVIRT_PORT=16509

# ---- 高可用（单节点部署保持 false 即可）----
CNF_HA_ENABLED=false
CNF_NODE_ID=
CNF_HA_LEASE_TTL_SEC=15
CNF_HA_RENEW_SEC=5
